{
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(mypy *)",
      "Bash(pyright *)",
      "Bash(pytest *)",
      "Bash(poetry *)",
      "Bash(pip *)",
      "Bash(pipx *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(deno *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(tsc *)",
      "Bash(biome *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vitest *)",
      "Bash(jest *)",
      "Bash(turbo *)",
      "Bash(nx *)",
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(rustc *)",
      "Bash(rustfmt *)",
      "Bash(swift *)",
      "Bash(swiftc *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(make *)",
      "Bash(just *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(ln *)",
      "Bash(chmod *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "WebSearch",
      "WebFetch"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.3 /System/Library/Sounds/Purr.aiff 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/consolidate-memory.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.3 /System/Library/Sounds/Submarine.aiff 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": false,
    "git@frad-dotclaude": true,
    "gitflow@frad-dotclaude": true,
    "playground@claude-plugins-official": false,
    "refactor@frad-dotclaude": false,
    "document-skills@anthropic-agent-skills": false,
    "github@frad-dotclaude": true,
    "exa-mcp-server@exa-mcp-server": true,
    "impeccable@impeccable": false,
    "superpowers@frad-dotclaude": true,
    "skill-creator@claude-plugins-official": true,
    "acpx@frad-dotclaude": true,
    "code-context@frad-dotclaude": true,
    "codex@openai-codex": true,
    "paper-desktop@paper": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      },
      "autoUpdate": true
    },
    "frad-dotclaude": {
      "source": {
        "source": "github",
        "repo": "FradSer/dotclaude"
      },
      "autoUpdate": true
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "paper": {
      "source": {
        "source": "github",
        "repo": "paper-design/agent-plugins"
      }
    }
  },
  "tui": "fullscreen",
  "channelsEnabled": true,
  "allowedChannelPlugins": [
    {
      "marketplace": "claude-plugins-official",
      "plugin": "telegram"
    },
    {
      "marketplace": "claude-plugins-official",
      "plugin": "discord"
    }
  ],
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": false,
  "teammateMode": "auto",
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
